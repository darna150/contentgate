{
  "name": "contentgate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:migrations && npm run test:assets && npm run test:workspace && npm run test:knowledge && npm run test:approval && npm run test:templates && npm run test:rate-limits && npm run test:documents && npm run test:data-helpers && npm run test:ui && npm run test:template-render",
    "test:migrations": "node scripts/check-migrations.mjs && node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/tenant-integrity-sql.test.ts",
    "test:assets": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/product-assets.test.ts src/lib/render-output-storage.test.ts src/lib/server-export-formats.test.ts",
    "test:workspace": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/product-workspace.test.ts",
    "test:knowledge": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/knowledge-hub.test.ts src/lib/knowledge-reliability.test.ts src/lib/evidence-validation.test.ts src/lib/evidence-lifecycle.test.ts",
    "test:approval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/content-governance.test.ts",
    "test:templates": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/template-contract.test.ts src/lib/template-platform/manifest.test.ts src/lib/template-platform/publish-readiness.test.ts src/lib/template-platform/preflight.test.ts src/lib/template-platform/bundle-directory.test.ts src/lib/template-platform/compiler.test.ts src/lib/template-platform/importer.test.ts src/lib/template-platform/figma-publisher.test.ts src/lib/template-platform/assignments.test.ts src/lib/template-platform/publishing.test.ts src/lib/template-platform/fit.test.ts",
    "test:rate-limits": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/rate-limit.test.ts",
    "test:documents": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/document-extraction.test.ts src/lib/document-index-status.test.ts",
    "test:data-helpers": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/content-listing-shared.test.ts src/lib/document-listing-shared.test.ts src/lib/generated-copy-quality.test.ts src/lib/template-ops-shared.test.ts src/lib/invites.test.ts",
    "test:ui": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/roving-focus.test.ts",
    "test:template-render": "tsx --test src/lib/template-renderer.test.tsx src/lib/template-platform/contentgate-bundle.test.ts src/lib/template-platform/contentgate-public-assets.test.ts src/lib/template-platform/runtime.test.ts src/lib/template-platform/render.test.tsx",
    "test:e2e": "playwright test",
    "smoke": "node scripts/smoke-test.mjs",
    "figwright:list": "node .tools/figwright/client.mjs list",
    "figwright:export-backgrounds": "node .tools/figwright/export-backgrounds.mjs",
    "figwright:create-background-options-source": "node .tools/figwright/create-background-options-source.mjs",
    "figwright:export-contentgate-bundles": "tsx scripts/template-platform/export-figwright-contentgate.ts",
    "contentgate:render-samples": "tsx .tools/render-contentgate-samples.tsx",
    "contentgate:contact-sheets": "node .tools/render-contact-sheet.mjs",
    "template-platform:write-contentgate-bundles": "tsx scripts/template-platform/write-contentgate-bundles.ts",
    "template-platform:write-figma-publisher-bundle": "tsx scripts/template-platform/write-figma-publisher-bundle.ts",
    "template-platform:preflight-bundle": "tsx scripts/template-platform/preflight-bundle.ts",
    "template-platform:preflight-contentgate": "tsx scripts/template-platform/preflight-contentgate.ts",
    "template-platform:install-contentgate": "tsx scripts/template-platform/install-contentgate-platform.ts",
    "template-platform:write-migration-sql": "tsx scripts/template-platform/write-platform-migration-sql.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/react-visually-hidden": "^1.2.7",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "ai": "^6.0.202",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.9",
    "officeparser": "^7.2.1",
    "opentype.js": "^2.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@figwright/mcp": "^0.3.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
