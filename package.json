{
  "name": "contentgate",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:migrations && npm run test:assets && npm run test:workspace && npm run test:knowledge && npm run test:approval && npm run test:templates && npm run test:rate-limits && npm run test:documents && npm run test:template-render",
    "test:migrations": "node scripts/check-migrations.mjs",
    "test:assets": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/product-assets.test.ts",
    "test:workspace": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/product-workspace.test.ts",
    "test:knowledge": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/knowledge-hub.test.ts src/lib/knowledge-reliability.test.ts",
    "test:approval": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/content-governance.test.ts",
    "test:templates": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/template-contract.test.ts",
    "test:rate-limits": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/rate-limit.test.ts",
    "test:documents": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/lib/document-extraction.test.ts",
    "test:template-render": "tsx --test src/lib/template-renderer.test.tsx",
    "smoke": "node scripts/smoke-test.mjs",
    "figwright:list": "node .tools/figwright/client.mjs list",
    "figwright:export-backgrounds": "node .tools/figwright/export-backgrounds.mjs",
    "contentgate:render-samples": "tsx .tools/render-contentgate-samples.tsx",
    "contentgate:contact-sheets": "node .tools/render-contact-sheet.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.83",
    "@anthropic-ai/sdk": "^0.104.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "ai": "^6.0.202",
    "html-to-image": "^1.11.13",
    "next": "16.2.9",
    "officeparser": "^7.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@figwright/mcp": "^0.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
